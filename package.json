{
  "name": "simpleterms-ui",
  "version": "0.1.12",
  "description": "Brutalist Win2000/IBM flat UI kit \u2014 React 19 + Tailwind v4 + Radix, extracted from simple-terms",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kvooak/simpleterms-ui.git"
  },
  "files": [
    "dist",
    "src"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./theme.css": "./src/theme.css"
  },
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "build": "tsup",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@fontsource-variable/ibm-plex-sans": "^5.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.3.1"
  },
  "peerDependencies": {
    "@tanstack/react-router": ">=1.0.0",
    "lucide-react": ">=0.400.0",
    "radix-ui": ">=1.4.0",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  },
  "devDependencies": {
    "@tanstack/react-router": "^1.166.3",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "lucide-react": "^0.475.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tsup": "^8.3.5",
    "typescript": "^5.3.3"
  }
}